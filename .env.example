# ============================================================
#  Inteliaudit — Variables de entorno
#  Copiar a .env y completar con valores reales
# ============================================================

# Base de datos
# Desarrollo (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./inteliaudit.db
# Producción (PostgreSQL - Supabase, Railway, Neon):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/inteliaudit

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Seguridad
SECRET_KEY=cambia-esto-en-produccion
DEBUG=false

# Storage — archivos descargados de Marangatú
STORAGE_PATH=./storage

# Marangatú (opcional — para scraper automático)
# Las credenciales por cliente se guardan en la DB cifradas
# Esta clave se usa para cifrar/descifrar
ENCRYPTION_KEY=clave-32-bytes-para-fernet

# CORS (producción)
ALLOWED_ORIGINS=https://app.inteliaudit.com
