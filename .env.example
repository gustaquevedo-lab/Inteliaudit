# ============================================================
#  Inteliaudit — Variables de entorno
#  Copiá este archivo como .env y completá los valores reales
# ============================================================

# Base de datos
# Desarrollo: SQLite (sin configuración extra)
DATABASE_URL=sqlite+aiosqlite:///./inteliaudit.db
# Producción Railway: Railway inyecta DATABASE_URL automáticamente al agregar Postgres plugin
# Producción manual (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/inteliaudit

# Seguridad JWT — OBLIGATORIO cambiar en producción
# Generá uno con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# Claude / Anthropic API (para análisis IA)
ANTHROPIC_API_KEY=

# App
DEBUG=false
STORAGE_PATH=./storage

# Cifrado credenciales Marangatú (opcional)
# Generá con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# CORS — en producción: tu dominio Railway
# ALLOWED_ORIGINS=["https://tu-app.up.railway.app"]
